{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeshPack Lab",
  "version": "0.1.0",
  "identifier": "com.meshpack.lab",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MeshPack Lab",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' blob: data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../src-tauri/icons/32x32.png",
      "../../src-tauri/icons/128x128.png",
      "../../src-tauri/icons/128x128@2x.png",
      "../../src-tauri/icons/icon.icns",
      "../../src-tauri/icons/icon.ico"
    ]
  },
  "plugins": {}
}
